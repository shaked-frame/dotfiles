keybind = ctrl+z=close_surface
keybind = ctrl+shift+v=new_split:right
keybind = ctrl+shift+d=new_split:down
keybind = ctrl+t>h=toggle_quick_terminal
keybind = ctrl+shift+M=toggle_split_zoom
keybind = ctrl+shift+equal=equalize_splits
keybind = ctrl+shift+right=resize_split:right,20
keybind = ctrl+shift+left=resize_split:left,20
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+o=toggle_tab_overview
keybind = super+l=goto_split:right
keybind = super+h=goto_split:left
macos-titlebar-style = hidden
macos-option-as-alt = true
# Word navigation (Option + Arrow)
keybind = alt+left=text:\x1b[1;3D
keybind = alt+right=text:\x1b[1;3C

# Line navigation (Cmd + Arrow)
keybind = cmd+left=text:\x1b[H
keybind = cmd+right=text:\x1b[F


font-family =  BitstromWera Nerd Font Mono
font-size = 14


theme = GitHub Dark Colorblind
background-opacity = 0.8
background-blur-radius = 50
window-padding-x=8
window-padding-y=8
maximize
unfocused-split-opacity = 0.9



focus-follows-mouse = true


font-feature = -liga
font-feature = -ss20
font-feature = -calt

window-padding-balance = true 
window-save-state = always
window-colorspace = "display-p3"
macos-titlebar-style = tabs

